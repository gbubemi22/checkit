{
  "name": "backend-assessment",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "proto:user": "protoc --plugin=./node_modules/.bin/protoc-gen-ts_proto -I=packages/proto --ts_proto_out=packages/proto/src --ts_proto_opt=nestJs=true,fileSuffix=.pb packages/proto/user.proto",
    "proto:wallet": "protoc --plugin=./node_modules/.bin/protoc-gen-ts_proto -I=packages/proto --ts_proto_out=packages/proto/src --ts_proto_opt=nestJs=true,fileSuffix=.pb packages/proto/wallet.proto",
    "proto:generate": "npm run proto:user && npm run proto:wallet",
    "start:gateway": "node -r @swc-node/register apps/api-gateway/src/main.ts",
    "start:user": "node -r @swc-node/register apps/user-service/src/main.ts",
    "start:wallet": "node -r @swc-node/register apps/wallet-service/src/main.ts",
    "dev:gateway": "node --watch -r @swc-node/register apps/api-gateway/src/main.ts",
    "dev:user": "node --watch -r @swc-node/register apps/user-service/src/main.ts",
    "dev:wallet": "node --watch -r @swc-node/register apps/wallet-service/src/main.ts",
    "prisma:generate": "prisma generate --schema packages/prisma/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema packages/prisma/prisma/schema.prisma",
    "prisma:deploy": "prisma migrate deploy --schema packages/prisma/prisma/schema.prisma"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.10.9",
    "@grpc/proto-loader": "^0.7.13",
    "@nestjs/common": "^10.4.8",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^10.4.8",
    "@nestjs/microservices": "^10.4.8",
    "@nestjs/platform-express": "^10.4.8",
    "@prisma/client": "^5.22.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "nestjs-pino": "^4.6.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.24",
    "@types/node": "^22.10.1",
    "prisma": "^5.22.0",
    "ts-proto": "^2.11.6",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
