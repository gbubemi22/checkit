{
  "name": "backend-assessment",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start:user": "tsx apps/user-service/src/main.ts",
    "start:wallet": "tsx apps/wallet-service/src/main.ts",
    "dev:user": "tsx watch apps/user-service/src/main.ts",
    "dev:wallet": "tsx watch apps/wallet-service/src/main.ts",
    "prisma:generate": "prisma generate --schema packages/prisma/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema packages/prisma/prisma/schema.prisma",
    "prisma:deploy": "prisma migrate deploy --schema packages/prisma/prisma/schema.prisma"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.10.9",
    "@grpc/proto-loader": "^0.7.13",
    "@nestjs/common": "^10.4.8",
    "@nestjs/core": "^10.4.8",
    "@nestjs/microservices": "^10.4.8",
    "@nestjs/platform-express": "^10.4.8",
    "@prisma/client": "^5.22.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
